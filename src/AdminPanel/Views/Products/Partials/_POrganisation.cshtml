@model AdminPanel.ViewModels.Products.ProductFormViewModel
@{
    var statusOptions = new[]
    {
        new { Value = "Draft",           DotClass = "dot-sky",     Label = "Draft",            Desc = "Not visible to customers" },
        new { Value = "PendingApproval", DotClass = "dot-amber",   Label = "Pending Approval", Desc = "Awaiting admin review"    },
        new { Value = "Active",          DotClass = "dot-emerald", Label = "Active",            Desc = "Live and purchasable"     },
        new { Value = "Rejected",        DotClass = "dot-rose",    Label = "Rejected",          Desc = "Requires seller action"   },
        new { Value = "Archived",        DotClass = "dot-neutral", Label = "Archived",          Desc = "Hidden from all listings" },
    };
}

<div class="panel-hd">
    <div class="panel-icon pi-rose">
        <svg width="16" height="16" fill="none" viewBox="0 0 24 24"
             stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round"
                  d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724
                     1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724
                     1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724
                     1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724
                     1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724
                     1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724
                     1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724
                     1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608
                     2.296.07 2.572-1.065z"/>
            <path stroke-linecap="round" stroke-linejoin="round"
                  d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
    </div>
    <div class="panel-hd-text">
        <div class="panel-title">Organisation &amp; Status</div>
        <div class="panel-sub">Control product status and featured placement</div>
    </div>
</div>

<div class="admin-notice">
    <svg width="13" height="13" fill="none" viewBox="0 0 24 24"
         stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round"
              d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955
                 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824
                 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622
                 0-1.042-.133-2.052-.382-3.016z"/>
    </svg>
    This section is visible to Admin accounts only
</div>


<div class="form-group">
    <label class="form-label">Product Status</label>
    <div class="status-picker" role="radiogroup" aria-label="Product status">
        @foreach (var s in statusOptions)
        {
            <label class="status-opt@(Model.Status == s.Value ? " is-on" : "")"
                   data-status-opt>
                <input type="radio"
                       name="Status"
                       value="@s.Value"
                       checked="@(Model.Status == s.Value)"
                       data-status-radio />
                <span class="status-opt-dot @s.DotClass"></span>
                <span class="status-opt-body">
                    <span class="status-opt-label">@s.Label</span>
                    <span class="status-opt-desc">@s.Desc</span>
                </span>
            </label>
        }
    </div>
</div>


<div class="form-group@(Model.Status != "Rejected" ? " is-hidden" : "")"
     id="rejReasonGroup"
     data-rejection-group
     data-rejection-trigger="Rejected">
    <label class="form-label" for="RejectionReason">
        Rejection Reason <span class="req">*</span>
    </label>
    <textarea asp-for="RejectionReason"
              id="RejectionReason"
              class="form-textarea"
              rows="3"
              placeholder="Explain to the seller why this product was rejected…"></textarea>
    <span class="form-hint">This message is visible to the seller.</span>
</div>


<div class="toggle-row">
    <div class="toggle-info">
        <span class="toggle-label">Featured Product</span>
        <span class="toggle-desc">
            Highlighted in featured sections on the homepage and category pages
        </span>
    </div>
    <label class="toggle">
        <input type="checkbox" asp-for="IsFeatured" value="true" />
        <span class="toggle-track">
            <span class="toggle-thumb"></span>
        </span>
    </label>
</div>
