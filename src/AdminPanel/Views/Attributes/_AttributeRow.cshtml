@using AdminPanel.ViewModels.Attributes
@model AttributeRowViewModel
@{
    var i = Model.Index;
    var row = Model.Row;
    var needsOptions = row.InputType is "Select" or "MultiSelect";
}
<div class="attr-row" data-index="@i">
    <div class="attr-row-grid">
        <div class="form-group">
            <label class="form-label">Name <span>*</span></label>
            <input name="Items[@i].AttributeName"
                   value="@row.AttributeName"
                   class="form-input"
                   placeholder="e.g. Screen Size"
                   required />
        </div>
        <div class="form-group">
            <label class="form-label">Input Type</label>
            <select name="Items[@i].InputType"
                    class="form-select attr-type-select"
                    onchange="toggleOptions(this)">
                @foreach (var t in new[] { "Text", "Number", "Boolean", "Select", "MultiSelect" })
                {
                    <option value="@t" selected="@(row.InputType == t)">@t</option>
                }
            </select>
        </div>
        <div class="form-group">
            <label class="form-label">
                Options
                <span class="form-label-note">comma-separated</span>
            </label>
            <input name="Items[@i].OptionsRaw"
                   value="@row.OptionsRaw"
                   class="form-input attr-options-input @(!needsOptions ? "attr-options-disabled" : "")"
                   placeholder="Red, Green, Blue" />
        </div>
        <div class="form-group">
            <label class="form-label">Sort</label>
            <input name="Items[@i].SortOrder"
                   value="@row.SortOrder"
                   type="number"
                   min="0"
                   class="form-input" />
        </div>
        <div class="form-group">
            <label class="form-label">Required</label>
            <label class="check-row check-row--compact">
                <input name="Items[@i].IsRequired" type="checkbox" class="cb" @(row.IsRequired ? "checked" : "") />
                <span class="check-row-label">Required</span>
            </label>
        </div>
        <div class="attr-row-action">
            <button type="button" class="row-btn danger attr-row-remove" title="Remove">
                <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <line x1="18" y1="6" x2="6" y2="18" />
                    <line x1="6" y1="6" x2="18" y2="18" />
                </svg>
            </button>
        </div>
    </div>
</div>