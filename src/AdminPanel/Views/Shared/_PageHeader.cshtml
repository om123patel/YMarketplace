@using AdminPanel.ViewModels.Common
@model PageHeaderModel

<div class="pg-bar">
    <div>
        <h1 class="pg-title">@Model.Title</h1>
        @if (!string.IsNullOrEmpty(Model.Subtitle))
        {
            <p class="pg-sub">@Model.Subtitle</p>
        }
    </div>
    @if (!string.IsNullOrEmpty(Model.ActionsHtml))
    {
        <div class="pg-actions">
            @Html.Raw(Model.ActionsHtml)
        </div>
    }
</div>
