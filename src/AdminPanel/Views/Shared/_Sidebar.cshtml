@{
    var ctrl = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
}

<div class="s-group">
    <div class="s-group-label">Overview</div>
    <a class="s-link @(ctrl == "Dashboard" ? "on" : "")"
       asp-controller="Dashboard" asp-action="Index">
        <svg class="s-ico" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <rect x="3" y="3" width="7" height="7" rx="1" />
            <rect x="14" y="3" width="7" height="7" rx="1" />
            <rect x="3" y="14" width="7" height="7" rx="1" />
            <rect x="14" y="14" width="7" height="7" rx="1" />
        </svg>
        Dashboard
    </a>
</div>

<div class="s-group">
    <div class="s-group-label">Catalog</div>
    <a class="s-link @(ctrl == "Products" ? "on" : "")"
       asp-controller="Products" asp-action="Index">
        <svg class="s-ico" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
        </svg>
        Products
    </a>
    <a class="s-link @(ctrl == "Categories" ? "on" : "")"
       asp-controller="Categories" asp-action="Index">
        <svg class="s-ico" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h16M4 18h16" />
        </svg>
        Categories
    </a>
    <a class="s-link @(ctrl == "Brands" ? "on" : "")"
       asp-controller="Brands" asp-action="Index">
        <svg class="s-ico" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h8M12 8v8" />
        </svg>
        Brands
    </a>
    <a class="s-link @(ctrl == "Tags" ? "on" : "")"
       asp-controller="Tags" asp-action="Index">
        <svg class="s-ico" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
        </svg>
        Tags
    </a>
    <a class="s-link @(ctrl == "AttributeTemplates" ? "on" : "")"
       asp-controller="AttributeTemplates" asp-action="Index">
        <svg class="s-ico" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
        </svg>
        Attributes
    </a>
</div>

<div class="s-group">
    <div class="s-group-label">People</div>
    <a class="s-link @(ctrl == "Sellers" ? "on" : "")"
       asp-controller="Sellers" asp-action="Index">
        <svg class="s-ico" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        Sellers
    </a>
    <a class="s-link @(ctrl == "Users" ? "on" : "")"
       asp-controller="Users" asp-action="Index">
        <svg class="s-ico" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
        </svg>
        Users
    </a>
</div>

<div class="s-group">
    <div class="s-group-label">Operations</div>
    <a class="s-link" href="#">
        <svg class="s-ico" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
        </svg>
        Orders
    </a>
</div>
