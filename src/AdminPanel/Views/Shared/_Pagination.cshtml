@using AdminPanel.ViewModels.Common
@model PaginationViewModel

@if (Model.TotalCount == 0) { return; }

<div class="pagination">
    <div class="pg-info">
        Showing @Model.FirstItemIndex–@Model.LastItemIndex
        of @Model.TotalCount.ToString("N0") results
    </div>
    <div class="pg-ctrl">

        @if (Model.HasPreviousPage)
        {
            var prev = new Dictionary<string, string?>(Model.RouteData)
            { ["page"] = (Model.Page - 1).ToString() };
            <a asp-action="@Model.Action" asp-controller="@Model.Controller"
               asp-all-route-data="prev" class="pg-btn" aria-label="Previous">
                <svg width="13" height="13" fill="none" viewBox="0 0 24 24"
                     stroke="currentColor" stroke-width="2.5">
                    <polyline points="15 18 9 12 15 6" />
                </svg>
            </a>
        }

        @for (int i = Math.Max(1, Model.Page - 2);
                i <= Math.Min(Model.TotalPages, Model.Page + 2); i++)
        {
            var pd = new Dictionary<string, string?>(Model.RouteData)
            { ["page"] = i.ToString() };
            <a asp-action="@Model.Action" asp-controller="@Model.Controller"
               asp-all-route-data="pd"
               class="pg-btn @(i == Model.Page ? "on" : "")"
               aria-current="@(i == Model.Page ? "page" : null)">@i</a>
        }

        @if (Model.HasNextPage)
        {
            var next = new Dictionary<string, string?>(Model.RouteData)
            { ["page"] = (Model.Page + 1).ToString() };
            <a asp-action="@Model.Action" asp-controller="@Model.Controller"
               asp-all-route-data="next" class="pg-btn" aria-label="Next">
                <svg width="13" height="13" fill="none" viewBox="0 0 24 24"
                     stroke="currentColor" stroke-width="2.5">
                    <polyline points="9 18 15 12 9 6" />
                </svg>
            </a>
        }

    </div>
</div>