@using AdminPanel.ViewModels
@using AdminPanel.ViewModels.Products
@model PaginationViewModel
@{
    var from  = (Model.Page - 1) * Model.PageSize + 1;
    var to    = Math.Min(Model.Page * Model.PageSize, Model.TotalCount);
    var route = Model.RouteData ?? [];
}

<div class="pagination">
    <div class="pg-info">
        @if (Model.TotalCount == 0)
        {
            <span>No results</span>
        }
        else
        {
            <span>Showing @from–@to of @Model.TotalCount.ToString("N0")</span>
        }
    </div>
    <div class="pg-ctrl">
        @if (Model.Page > 1)
        {
            <a asp-controller="@Model.Controller"
               asp-action="@Model.Action"
               asp-route-page="@(Model.Page - 1)"
               asp-all-route-data="route"
               class="pg-btn" aria-label="Previous">
                <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <polyline points="15 18 9 12 15 6"/>
                </svg>
            </a>
        }
        else
        {
            <span class="pg-btn pg-btn--disabled" aria-disabled="true">
                <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <polyline points="15 18 9 12 15 6"/>
                </svg>
            </span>
        }

        @{
            int startPage = Math.Max(1, Model.Page - 2);
            int endPage   = Math.Min(Model.TotalPages, Model.Page + 2);

            // Always show first page link if we're far in
            if (startPage > 2)
            {
                <a asp-controller="@Model.Controller" asp-action="@Model.Action"
                   asp-route-page="1" asp-all-route-data="route" class="pg-btn">1</a>
                if (startPage > 3) { <span class="pg-ellipsis">…</span> }
            }
        }

        @for (int i = startPage; i <= endPage; i++)
        {
            <a asp-controller="@Model.Controller"
               asp-action="@Model.Action"
               asp-route-page="@i"
               asp-all-route-data="route"
               class="pg-btn @(i == Model.Page ? "on" : "")">@i</a>
        }

        @{
            if (endPage < Model.TotalPages - 1) { <span class="pg-ellipsis">…</span> }
            if (endPage < Model.TotalPages)
            {
                <a asp-controller="@Model.Controller" asp-action="@Model.Action"
                   asp-route-page="@Model.TotalPages" asp-all-route-data="route"
                   class="pg-btn">@Model.TotalPages</a>
            }
        }

        @if (Model.Page < Model.TotalPages)
        {
            <a asp-controller="@Model.Controller"
               asp-action="@Model.Action"
               asp-route-page="@(Model.Page + 1)"
               asp-all-route-data="route"
               class="pg-btn" aria-label="Next">
                <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <polyline points="9 18 15 12 9 6"/>
                </svg>
            </a>
        }
        else
        {
            <span class="pg-btn pg-btn--disabled" aria-disabled="true">
                <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <polyline points="9 18 15 12 9 6"/>
                </svg>
            </span>
        }
    </div>
</div>
