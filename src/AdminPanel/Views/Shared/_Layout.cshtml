<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@(ViewData["Title"] ?? "Dashboard") — MarketHub Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,600;12..96,700;12..96,800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true">

    <link rel="stylesheet" href="~/css/table-filters.css" asp-append-version="true">
</head>
<body>

    @if (TempData["Success"] is string successMsg)
    {
        <div class="toast toast-success" id="toast">@successMsg</div>
    }
    @if (TempData["Error"] is string errorMsg)
    {
        <div class="toast toast-error" id="toast">@errorMsg</div>
    }

    <div class="overlay" id="overlay" onclick="closeSidebar()"></div>

    <div class="shell">

        <!-- SIDEBAR -->
        <aside class="sidebar" id="sidebar">
            <div class="s-logo">
                <div class="s-logo-mark">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
                    </svg>
                </div>
                <div class="s-logo-name">Market<em>Hub</em></div>
            </div>

            @await Html.PartialAsync("_Sidebar")

            <div class="s-footer">
                <form asp-controller="Auth" asp-action="Logout" method="post">
                    @Html.AntiForgeryToken()
                    <div class="s-user">
                        <div class="s-av" style="background:var(--c-indigo);color:#fff">
                            @(User.Identity?.Name?.FirstOrDefault().ToString().ToUpper() ?? "A")
                        </div>
                        <div>
                            <div class="s-uname">@User.Identity?.Name</div>
                            <div class="s-urole">Super Admin</div>
                        </div>
                        <button type="submit" class="s-logout-btn" title="Logout">
                            <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                            </svg>
                        </button>
                    </div>
                </form>
            </div>
        </aside>

        <!-- HEADER -->
        <header class="header">
            <button class="h-burger" id="burger" onclick="toggleSidebar()" aria-label="Menu">
                <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
                </svg>
            </button>

            <div class="h-bread">
                MarketHub
                <div class="h-bread-dot"></div>
                <strong>@(ViewData["Title"] ?? "Dashboard")</strong>
            </div>

            <div class="h-search">
                <svg class="h-search-ico" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
                <input type="text" placeholder="Search products, orders…" aria-label="Search">
            </div>

            <div class="h-right">
                <div class="h-av">@(User.Identity?.Name?.FirstOrDefault().ToString().ToUpper() ?? "A")</div>
            </div>
        </header>

        <!-- BODY -->
        <main class="body">
            @RenderBody()
        </main>

    </div>

    <script src="~/js/admin.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>