@using AdminPanel.ViewModels.Common
@model ListFilterBarModel

<div class="filter-bar">

   
    <div class="filter-search">
        <svg class="filter-search-ico" width="14" height="14" fill="none"
             viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <circle cx="11" cy="11" r="8" />
            <line x1="21" y1="21" x2="16.65" y2="16.65" />
        </svg>
        <input name="@Model.SearchParam"
               value="@Model.SearchValue"
               placeholder="@Model.Placeholder"
               class="filter-input"
               autocomplete="off" />
    </div>
   
    @if (Model.StatusTabs.Count > 0)
    {
        <div class="tab-group" role="tablist">
            @foreach (var tab in Model.StatusTabs)
            {
                var tabCls = "tab" + (tab.IsActive ? " on" : "");
                <a href="@tab.Href" class="@tabCls" role="tab"
                   aria-selected="@tab.IsActive.ToString().ToLower()">
                    @tab.Label
                    @if (tab.Count.HasValue)
                    {
                        <span class="tab-count">@tab.Count</span>
                    }
                </a>
            }
        </div>
    }


    <div class="f-right">
        <button type="submit" class="btn btn-outline btn-sm">Search</button>

        @if (Model.HasFilters)
        {
            <a href="@Model.ClearUrl" class="btn btn-ghost btn-sm">Clear</a>
        }

       
        @{
            var toggleCls = "btn btn-outline btn-sm tf-toggle-btn"
            + (Model.HasFilters ? " tf-toggle--active" : "");
        }
        <button type="button" class="@toggleCls"
                data-tf-toggle="tf-panel-@Model.FormId"
                aria-expanded="false"
                aria-controls="tf-panel-@Model.FormId"
                aria-label="Toggle advanced filters">
            <svg width="13" height="13" fill="none" viewBox="0 0 24 24"
                 stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round"
                      d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2a1 1 0 01-.293.707
                         L13 13.414V19a1 1 0 01-.553.894l-4 2A1 1 0 017
                         21v-7.586L3.293 6.707A1 1 0 013 6V4z" />
            </svg>
            Filters
            @if (Model.HasFilters)
            {
                <span class="tf-badge" aria-label="@Model.FilterCount active filters">
                    @Model.FilterCount
                </span>
            }
            <svg class="tf-toggle-chev" width="11" height="11" fill="none"
                 viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"
                 aria-hidden="true">
                <polyline points="6 9 12 15 18 9" />
            </svg>
        </button>
    </div>

</div>