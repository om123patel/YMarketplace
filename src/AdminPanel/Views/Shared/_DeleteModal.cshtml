@using AdminPanel.ViewModels.Common
@model DeleteModalModel

<div class="modal-backdrop" id="delModal" style="display:none"
     onclick="if(event.target===this)this.style.display='none'">
    <div class="modal-card">
        <div class="modal-title">@Model.Title</div>
        <p class="modal-desc" id="delModalDesc">@Model.Description</p>
        <div class="modal-actions">
            <button type="button" class="btn btn-outline"
                    onclick="document.getElementById('delModal').style.display='none'">
                Cancel
            </button>
            <form id="delForm" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger">
                    @(Model.ButtonLabel ?? "Delete")
                </button>
            </form>
        </div>
    </div>
</div>
