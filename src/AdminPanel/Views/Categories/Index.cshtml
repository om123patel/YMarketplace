@using AdminPanel.ViewModels.Categories
@model CategoryListViewModel
@{
    ViewData["Title"] = "Categories";

}

<div class="pg-bar">
    <div>
        <h1 class="pg-title">Categories</h1>
        @* <p class="pg-sub">@Model.TotalCount total &middot; @Model.ActiveCount active &middot; @Model.InactiveCount inactive</p> *@
    </div>
    <div class="pg-actions">
        <a asp-action="Create" class="btn btn-primary">
            <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
            New Category
        </a>
    </div>
</div>

@if (TempData["Success"] is string ok)
{
    <div class="alert alert-emerald"><div class="alert-icon">✓</div><div class="alert-body"><div class="alert-title">@ok</div></div></div>
}
@if (TempData["Error"] is string err)
{
    <div class="alert alert-rose"><div class="alert-icon">✕</div><div class="alert-body"><div class="alert-title">@err</div></div></div>
}

<div class="card">
    <form method="get" class="filter-bar">
        <div class="filter-search">
            <svg class="filter-search-ico" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
            <input name="search" value="@Model.Search" placeholder="Search categories…" class="filter-input" />
        </div>
        <input type="hidden" name="sortBy" value="@Model.SortBy" />
        <input type="hidden" name="sortDirection" value="@Model.SortDirection" />
        <div class="tab-group">
            <a href="?search=@Uri.EscapeDataString(Model.Search ?? "")&sortBy=@Model.SortBy&sortDirection=@Model.SortDirection"
               class="tab @(string.IsNullOrEmpty(Model.StatusFilter) ? "on" : "")">All <span class="tab-count">@Model.TotalCount</span></a>
            @* <a href="?search=@Uri.EscapeDataString(Model.Search ?? "")&status=active&sortBy=@Model.SortBy&sortDirection=@Model.SortDirection"
               class="tab @(Model.StatusFilter == "active" ? "on" : "")">Active <span class="tab-count">@Model.ActiveCount</span></a>
            <a href="?search=@Uri.EscapeDataString(Model.Search ?? "")&status=inactive&sortBy=@Model.SortBy&sortDirection=@Model.SortDirection"
               class="tab @(Model.StatusFilter == "inactive" ? "on" : "")">Inactive <span class="tab-count">@Model.InactiveCount</span></a> *@
        </div>
        <div class="f-right">
            <button type="submit" class="btn btn-outline btn-sm">Search</button>
            @if (!string.IsNullOrEmpty(Model.Search))
            {
                <a asp-action="Index" class="btn btn-ghost btn-sm">Clear</a>
            }
        </div>
    </form>

    @if (!Model.Items.Any())
    {
        <div class="empty-state">
            <div class="empty-icon"><svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg></div>
            <div class="empty-title">No categories found</div>
            <div class="empty-desc">Create your first category to start organising products.</div>
            <a asp-action="Create" class="btn btn-primary btn-sm">New Category</a>
        </div>
    }
    else
    {
        <div class="tbl-wrap">
            <table>
                <thead>
                    <tr>
                        <th>
                            <a href="?search=@Model.Search&status=@Model.StatusFilter&sortBy=name&sortDirection=@Model.NextDirection("name")&page=1" class="sort-link">
                                Name @Model.SortIcon("name")
                            </a>
                        </th>
                        <th>Parent</th>
                        <th>
                            <a href="?search=@Model.Search&status=@Model.StatusFilter&sortBy=name&sortDirection=@Model.NextDirection("products")&page=1" class="sort-link">
                                Products @Model.SortIcon("products")
                            </a>


                        </th>
                        <th>
                            <a href="?search=@Model.Search&status=@Model.StatusFilter&sortBy=name&sortDirection=@Model.NextDirection("sort")&page=1" class="sort-link">
                                Order @Model.SortIcon("sort")
                            </a>
                        </th>

                        
                        <th>Status</th>
                        <th style="width:100px">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>
                                <div style="display:flex;align-items:center;gap:10px;@(item.Depth > 0 ? "padding-left:28px" : "")">
                                    @if (!string.IsNullOrEmpty(item.IconUrl))
                                    {
                                        <img src="@item.IconUrl" style="width:22px;height:22px;border-radius:4px;object-fit:cover;" />
                                    }
                                    else
                                    {
                                        <span style="width:22px;height:22px;border-radius:4px;background:@(item.Depth == 0 ? "var(--c-indigo-lt)" : "var(--c-canvas)");display:flex;align-items:center;justify-content:center;flex-shrink:0">
                                            <svg width="11" height="11" fill="none" viewBox="0 0 24 24" stroke="@(item.Depth == 0 ? "var(--c-indigo)" : "var(--c-ink-4)")" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>
                                        </span>
                                    }
                                    <div>
                                        <div class="tbl-link">@item.Name</div>
                                        <span class="tbl-mono tbl-meta">@item.Slug</span>
                                    </div>
                                    @if (item.ChildCount > 0)
                                    {
                                        <span class="badge badge-gray badge-xs">@item.ChildCount sub</span>
                                    }
                                </div>
                            </td>
                            <td class="tbl-meta">@(item.ParentName ?? "—")</td>
                            <td>
                                @if (item.ProductCount > 0)
                                {
                                    <span class="badge badge-indigo">@item.ProductCount</span>
                                }
                                else
                                {

                                    <span class="tbl-meta">0</span>
                                }
                        </td>
                        <td class="tbl-mono">@item.SortOrder</td>
                        <td>
                            <span class="badge @(item.IsActive ? "badge-emerald" : "badge-gray")">@(item.IsActive ? "Active" : "Inactive")</span>
                        </td>
                        <td>
                            <div class="row-acts">
                                <form asp-action="Toggle" asp-route-id="@item.Id" method="post" style="display:inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="activate" value="@(!item.IsActive ? "true" : "false")" />
                                    <button type="submit" class="row-btn @(item.IsActive ? "" : "approve")" title="@(item.IsActive ? "Deactivate" : "Activate")">
                                        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M18.364 5.636a9 9 0 11-12.728 0" /><line x1="12" y1="2" x2="12" y2="12" /></svg>
                                    </button>
                                </form>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="row-btn" title="Edit">
                                    <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>
                                </a>
                                <button type="button" class="row-btn danger" title="Delete"
                                        @(item.ProductCount > 0 || item.ChildCount > 0
                                                                            ? "disabled"
                                                                            : $"onclick=\"openDelModal({item.Id},'{Html.Encode(item.Name)}')\"")>
                                <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6" /><path stroke-linecap="round" stroke-linejoin="round" d="M19 6l-1 14H6L5 6m5 0V4h4v2" /></svg>
                            </button>
                        </div>
                    </td>
                </tr>
                                }
                </tbody>
            </table>
        </div>
    }
</div>

<div class="modal-backdrop" id="delModal" style="display:none" onclick="if(event.target===this)this.style.display='none'">
    <div class="modal-card">
        <div class="modal-title">Delete category?</div>
        <p class="modal-desc" id="delModalDesc"></p>
        <div class="modal-actions">
            <button type="button" class="btn btn-outline" onclick="document.getElementById('delModal').style.display='none'">Cancel</button>
            <form id="delForm" method="post">@Html.AntiForgeryToken()<button type="submit" class="btn btn-danger">Delete</button></form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openDelModal(id, name) {
            document.getElementById('delModalDesc').textContent = `Delete "${name}"? Products will be unaffected but unassigned.`;
            document.getElementById('delForm').action = `/Categories/${id}/Delete`;
            document.getElementById('delModal').style.display = 'flex';
        }
    </script>
}