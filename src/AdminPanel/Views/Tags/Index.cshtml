@using AdminPanel.ViewModels.Tags

@model TagListViewModel
@{
    ViewData["Title"] = "Tags";

    TableColumnModel Col(string label, string column, string? width = null) => new()
    {
        Label = label,
        Sortable = true,
        Column = column,
        SortBy = Model.SortBy,
        SortDirection = Model.SortDirection,
        Request = Context.Request,
        Width = width
    };

    TableColumnModel Plain(string label, string? width = null, string align = "left") => new()
    {
        Label = label,
        Sortable = false,
        Width = width,
        Align = align
    };
}

<div class="pg-bar">
    <div>
        <h1 class="pg-title">Tags</h1>
        <p class="pg-sub">@Model.TotalCount tag@(Model.TotalCount == 1 ? "" : "s") total</p>
    </div>
    <div class="pg-actions">
        <a asp-action="Create" class="btn btn-primary">
            <svg width="13" height="13" fill="none" viewBox="0 0 24 24"
                 stroke="currentColor" stroke-width="2.5">
                <line x1="12" y1="5" x2="12" y2="19" />
                <line x1="5" y1="12" x2="19" y2="12" />
            </svg>
            New Tag
        </a>
    </div>
</div>

<partial name="_AlertBanner" />

<div class="card">

    <form method="get" class="filter-bar">

        <input type="hidden" name="sortBy" value="@Model.SortBy" />
        <input type="hidden" name="sortDirection" value="@Model.SortDirection" />

        <div class="filter-search">
            <svg class="filter-search-ico" width="14" height="14" fill="none"
                 viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <circle cx="11" cy="11" r="8" />
                <line x1="21" y1="21" x2="16.65" y2="16.65" />
            </svg>
            <input name="search" value="@Model.Search"
                   placeholder="Search tags…" class="filter-input" />
        </div>

        <div class="f-right">
            <button type="submit" class="btn btn-outline btn-sm">Search</button>
            @if (!string.IsNullOrEmpty(Model.Search))
            {
                <a asp-action="Index" class="btn btn-ghost btn-sm">Clear</a>
            }
        </div>

    </form>

    @if (!Model.Items.Any())
    {
        <div class="empty-state">
            <div class="empty-icon">
                <svg width="28" height="28" fill="none" viewBox="0 0 24 24"
                     stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
                </svg>
            </div>
            <div class="empty-title">No tags yet</div>
            <div class="empty-desc">Tags group products across categories for filtering and discovery.</div>
            <a asp-action="Create" class="btn btn-primary btn-sm">New Tag</a>
        </div>
    }
    else
    {
        <div class="tbl-wrap">
            <table>
                <thead>
                    <tr>
                        <partial name="_TableColumn" model="@Col("Name", "name")" />
                        <partial name="_TableColumn" model="@Plain("Slug")" />
                        <partial name="_TableColumn" model="@Col("Products", "products")" />
                        <partial name="_TableColumn" model="@Col("Created", "created", "120px")" />
                        <partial name="_TableColumn" model="@Plain("Actions", "90px", "center")" />
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in Model.Items)
                    {
                        <tr>

                            <td>
                                <span style="display:inline-flex;align-items:center;gap:6px;
                                                     background:var(--c-indigo-lt);color:var(--c-indigo);
                                                     font-size:12.5px;font-weight:600;
                                                     padding:4px 10px;border-radius:20px">
                                    <svg width="10" height="10" fill="none" viewBox="0 0 24 24"
                                         stroke="currentColor" stroke-width="2.5">
                                        <path stroke-linecap="round" stroke-linejoin="round"
                                              d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
                                    </svg>
                                    @t.Name
                                </span>
                            </td>

                            <td class="tbl-mono">#@t.Slug</td>

                            <td>
                                @if (t.ProductCount > 0)
                                {
                                    <span class="badge badge-indigo">@t.ProductCount</span>
                                }
                                else
                                {
                                    <span class="tbl-meta">0</span>
                                }
                        </td>

                       
                        <td class="tbl-date">@t.CreatedAt.ToString("dd MMM yyyy")</td>

                        
                        <td>
                            <div class="row-acts">

                                <a asp-action="Edit" asp-route-id="@t.Id"
                                   class="row-btn" title="Edit">
                                    <svg width="14" height="14" fill="none"
                                         viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round"
                                              d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                    </svg>
                                </a>

                                <button type="button"
                                        class="row-btn danger"
                                        title="Delete"
                                        @(t.ProductCount > 0
                                                                            ? "disabled"
                                                                            : $"onclick=\"openDelModal({t.Id},'{Html.Encode(t.Name)}')\"")>
                                <svg width="14" height="14" fill="none"
                                     viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <polyline points="3 6 5 6 21 6" />
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                          d="M19 6l-1 14H6L5 6m5 0V4h4v2" />
                                </svg>
                            </button>

                                </div>
                            </td>

                        </tr>
                                }
                </tbody>
            </table>
        </div>

        <partial name="_Pagination" model="@(new PaginationViewModel
                                    {
                                        Page = Model.Page,
                                        PageSize = Model.PageSize,
                                        TotalCount = Model.TotalCount,
                                        RouteData = Model.RouteData,
                                        Action = "Index",
                                        Controller = "Tags"
                                    })" />
    }

</div>

<div class="modal-backdrop" id="delModal" style="display:none"
     onclick="if(event.target===this)this.style.display='none'">
    <div class="modal-card">
        <div class="modal-title">Delete tag?</div>
        <p class="modal-desc" id="delModalDesc"></p>
        <div class="modal-actions">
            <button type="button" class="btn btn-outline"
                    onclick="document.getElementById('delModal').style.display='none'">
                Cancel
            </button>
            <form id="delForm" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger">Delete</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openDelModal(id, name) {
            document.getElementById('delModalDesc').textContent =
                `Delete tag "${name}"? This cannot be undone.`;
            document.getElementById('delForm').action = `/Tags/${id}/Delete`;
            document.getElementById('delModal').style.display = 'flex';
        }
    </script>
}
