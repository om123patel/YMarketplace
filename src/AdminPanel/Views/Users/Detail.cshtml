@using AdminPanel.ViewModels.Auth
@using AdminPanel.Helpers
@model UserDetailViewModel
@{
    ViewData["Title"] = Model.FullName;
    var returnUrl = Context.Request.Path + Context.Request.QueryString;
}

<div class="pg-bar">
    <div>
        <div class="pg-eyebrow">
            <a asp-action="Index">Users</a>
            <span class="pg-eyebrow-sep">›</span>
            <span>@Model.FullName</span>
        </div>
        <h1 class="pg-title">@Model.FullName</h1>
        <p class="pg-sub">@Model.Role account · joined @Model.CreatedAt.ToString("dd MMM yyyy")</p>
    </div>
    <div class="pg-actions">
        <a asp-action="Index" class="btn btn-outline btn-sm">← Back to Users</a>

        @if (Model.CanActivate)
        {
            <form asp-action="Activate" asp-route-id="@Model.Id" method="post" style="display:inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@returnUrl" />
                <button type="submit" class="btn btn-primary btn-sm">Activate Account</button>
            </form>
        }

        @if (Model.CanSuspend)
        {
            <button type="button" class="btn btn-outline btn-sm"
                    onclick="document.getElementById('suspendPanel').style.display='block'">
                Suspend User
            </button>
        }
    </div>
</div>

<partial name="_AlertBanner" />


@if (Model.CanSuspend)
{
    <div id="suspendPanel" style="display:none">
        <div class="card" style="border-color:#fecdd3">
            <div class="card-head" style="background:#fff8f8;border-color:#fecdd3">
                <div class="card-title" style="color:var(--c-rose)">Suspend User</div>
            </div>
            <div class="card-body">
                <form asp-action="Suspend" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="returnUrl" value="@Url.Action("Detail", new { id = Model.Id })" />
                    <div class="form-group" style="margin-bottom:16px">
                        <label class="form-label">Reason <span>*</span></label>
                        <textarea name="reason" class="form-textarea" rows="3"
                                  placeholder="Explain why this account is being suspended…" required></textarea>
                    </div>
                    <div class="form-actions">
                        <button type="button" class="btn btn-ghost btn-sm"
                                onclick="document.getElementById('suspendPanel').style.display='none'">
                            Cancel
                        </button>
                        <button type="submit" class="btn btn-danger btn-sm">Confirm Suspend</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

<div class="detail-grid">

   
    <div class="detail-main">

       
        <div class="card">
            <div class="card-head">
                <div class="card-title">Profile</div>
            </div>
            <div class="card-body">

                <div style="display:flex;align-items:center;gap:18px;margin-bottom:24px;
                            padding-bottom:20px;border-bottom:1px solid var(--c-border)">
                    @if (!string.IsNullOrEmpty(Model.AvatarUrl))
                    {
                        <img src="@Model.AvatarUrl" alt="@Model.FullName"
                             style="width:64px;height:64px;border-radius:50%;object-fit:cover;
                                    border:2px solid var(--c-border)" />
                    }
                    else
                    {
                        <div style="width:64px;height:64px;border-radius:50%;
                                    background:var(--c-indigo-lt);color:var(--c-indigo);
                                    display:flex;align-items:center;justify-content:center;
                                    font-family:var(--f-display);font-size:26px;font-weight:800;
                                    flex-shrink:0">
                            @Model.FullName.FirstOrDefault()
                        </div>
                    }
                    <div>
                        <div style="font-family:var(--f-display);font-size:20px;font-weight:800;
                                    color:var(--c-ink);letter-spacing:-.4px">
                            @Model.FullName
                        </div>
                        <div style="font-size:13px;color:var(--c-ink-3);margin-top:3px">
                            @Model.Email
                        </div>
                        <div style="display:flex;align-items:center;gap:8px;margin-top:8px">
                            <span class="@BadgeHelper.UserRole(Model.Role)">@Model.Role</span>
                            <span class="@BadgeHelper.UserStatus(Model.Status)">
                                @BadgeHelper.UserStatusLabel(Model.Status)
                            </span>
                            @if (Model.IsLocked)
                            {
                                <span class="badge b-rejected">Locked</span>
                            }
                        </div>
                    </div>
                </div>

                <div class="field-grid-2">
                    <div class="form-group">
                        <label class="form-label">Email Address</label>
                        <div style="font-size:13.5px;color:var(--c-ink);padding:9px 0">
                            @Model.Email
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Phone Number</label>
                        <div style="font-size:13.5px;color:@(string.IsNullOrEmpty(Model.PhoneNumber) ? "var(--c-ink-4)" : "var(--c-ink)");padding:9px 0">
                            @(string.IsNullOrEmpty(Model.PhoneNumber) ? "Not provided" : Model.PhoneNumber)
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Role</label>
                        <div style="padding:9px 0">
                            <span class="@BadgeHelper.UserRole(Model.Role)">@Model.Role</span>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Account Status</label>
                        <div style="padding:9px 0">
                            <span class="@BadgeHelper.UserStatus(Model.Status)">
                                @BadgeHelper.UserStatusLabel(Model.Status)
                            </span>
                        </div>
                    </div>
                </div>

            </div>
        </div>

       
        <div class="card">
            <div class="card-head">
                <div class="card-title">Security & Login</div>
            </div>
            <div class="card-body">
                <div class="field-grid-2">
                    <div>
                        <label class="form-label">Last Login</label>
                        <div style="font-size:13.5px;color:var(--c-ink);margin-top:4px">
                            @(Model.LastLoginAt.HasValue
                                ? Model.LastLoginAt.Value.ToString("dd MMM yyyy, HH:mm") + " UTC"
                                : "Never logged in")
                        </div>
                    </div>
                    <div>
                        <label class="form-label">Failed Login Attempts</label>
                        <div style="margin-top:4px">
                            @if (Model.FailedLoginAttempts == 0)
                            {
                                <span style="font-size:13.5px;color:var(--c-emerald);font-weight:600">0 — Clean</span>
                            }
                            else if (Model.FailedLoginAttempts >= 3)
                            {
                                <span class="badge b-rejected">@Model.FailedLoginAttempts attempts</span>
                            }
                            else
                            {
                                <span style="font-size:13.5px;color:var(--c-amber);font-weight:600">
                                    @Model.FailedLoginAttempts attempt@(Model.FailedLoginAttempts == 1 ? "" : "s")
                                </span>
                            }
                        </div>
                    </div>
                    @if (Model.IsLocked)
                    {
                        <div>
                            <label class="form-label">Locked Until</label>
                            <div style="font-size:13.5px;color:var(--c-rose);margin-top:4px;font-weight:600">
                                @Model.LockedUntil!.Value.ToString("dd MMM yyyy, HH:mm") UTC
                            </div>
                        </div>
                    }
                    <div>
                        <label class="form-label">Member Since</label>
                        <div style="font-size:13.5px;color:var(--c-ink);margin-top:4px">
                            @Model.CreatedAt.ToString("dd MMM yyyy")
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>

   
    <div class="detail-side">

      
        <div class="card">
            <div class="card-head"><div class="card-title">Details</div></div>
            <div class="card-body">
                <div class="detail-kv">
                    <span class="detail-k">User ID</span>
                    <span class="detail-v tbl-mono" style="font-size:11px">
                        @Model.Id.ToString()[..8]…
                    </span>
                </div>
                <div class="detail-kv">
                    <span class="detail-k">Role</span>
                    <span class="detail-v">@Model.Role</span>
                </div>
                <div class="detail-kv">
                    <span class="detail-k">Status</span>
                    <span class="detail-v">
                        <span class="@BadgeHelper.UserStatus(Model.Status)">
                            @BadgeHelper.UserStatusLabel(Model.Status)
                        </span>
                    </span>
                </div>
                <div class="detail-kv">
                    <span class="detail-k">Last Login</span>
                    <span class="detail-v tbl-date">
                        @(Model.LastLoginAt.HasValue
                            ? Model.LastLoginAt.Value.ToString("dd MMM yyyy")
                            : "Never")
                    </span>
                </div>
                <div class="detail-kv">
                    <span class="detail-k">Joined</span>
                    <span class="detail-v tbl-date">@Model.CreatedAt.ToString("dd MMM yyyy")</span>
                </div>
                <div class="detail-kv">
                    <span class="detail-k">Updated</span>
                    <span class="detail-v tbl-date">@Model.UpdatedAt.ToString("dd MMM yyyy")</span>
                </div>
            </div>
        </div>

      
        <div class="card">
            <div class="card-head"><div class="card-title">Actions</div></div>
            <div class="card-body" style="display:flex;flex-direction:column;gap:8px">

                @if (Model.CanActivate)
                {
                    <form asp-action="Activate" asp-route-id="@Model.Id" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="returnUrl"
                               value="@Url.Action("Detail", new { id = Model.Id })" />
                        <button type="submit" class="btn btn-primary btn-sm"
                                style="width:100%;justify-content:center">
                            ✓ Activate Account
                        </button>
                    </form>
                }

                @if (Model.CanSuspend)
                {
                    <button type="button" class="btn btn-outline btn-sm"
                            style="width:100%;justify-content:center"
                            onclick="document.getElementById('suspendPanel').style.display='block';
                                     document.getElementById('suspendPanel').scrollIntoView({behavior:'smooth'})">
                        Suspend User
                    </button>
                }

                @if (Model.CanDelete)
                {
                    <button type="button" class="btn btn-danger btn-sm"
                            style="width:100%;justify-content:center"
                            onclick="document.getElementById('delModal').style.display='flex'">
                        Delete User
                    </button>
                }

            </div>
        </div>

       
        @if (Model.CanDelete)
        {
            <div class="card card--danger">
                <div class="card-head card-head--danger">
                    <div class="card-title card-title--danger">Danger Zone</div>
                </div>
                <div class="card-body">
                    <p class="danger-desc">
                        Permanently deletes this user account and all associated data. This cannot be undone.
                    </p>
                    <button type="button" class="btn btn-danger btn-sm"
                            onclick="document.getElementById('delModal').style.display='flex'">
                        Delete Account
                    </button>
                </div>
            </div>
        }

    </div>
</div>


@if (Model.CanDelete)
{
    <div class="modal-backdrop" id="delModal" style="display:none"
         onclick="if(event.target===this)this.style.display='none'">
        <div class="modal-card">
            <div class="modal-title">Delete "@Model.FullName"?</div>
            <p class="modal-desc">
                This will permanently remove the account and cannot be undone.
            </p>
            <div class="modal-actions">
                <button type="button" class="btn btn-outline"
                        onclick="document.getElementById('delModal').style.display='none'">
                    Cancel
                </button>
                <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">Delete Account</button>
                </form>
            </div>
        </div>
    </div>
}
