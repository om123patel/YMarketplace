@using AdminPanel.ViewModels
@using AdminPanel.ViewModels.Auth
@model LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Sign In";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign In — MarketHub Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,600;12..96,700;12..96,800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true">
</head>

<body class="page--login">

    <!-- ═══════════ LEFT — Brand Panel ═══════════ -->
    <div class="login-brand">
        <div class="login-brand__top">

            <div class="login-brand__logo">
                <div class="login-brand__mark">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
                    </svg>
                </div>
                <span class="login-brand__name">Market<em>Hub</em></span>
            </div>

            <h1 class="login-brand__headline">
                Your marketplace,<br>
                <em>fully in control.</em>
            </h1>

            <p class="login-brand__sub">
                Manage products, approve sellers, track orders,
                and grow your platform — all from one place.
            </p>

        </div>

        <div class="login-brand__cards">

            <div class="login-stat-card">
                <div class="login-stat-icon login-stat-icon--indigo">
                    <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="rgba(167,163,247,.9)" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                    </svg>
                </div>
                <div>
                    <div class="login-stat-val">4,821</div>
                    <div class="login-stat-lbl">Active products live</div>
                </div>
                <div class="login-stat-badge">↑ 12%</div>
            </div>

            <div class="login-stat-card">
                <div class="login-stat-icon login-stat-icon--emerald">
                    <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="rgba(52,211,153,.9)" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                </div>
                <div>
                    <div class="login-stat-val">₹4,82,000</div>
                    <div class="login-stat-lbl">Revenue this month</div>
                </div>
                <div class="login-stat-badge">↑ 14.5%</div>
            </div>

            <div class="login-stat-card">
                <div class="login-stat-icon login-stat-icon--amber">
                    <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="rgba(251,191,36,.9)" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                </div>
                <div>
                    <div class="login-stat-val">218</div>
                    <div class="login-stat-lbl">Verified sellers</div>
                </div>
                <div class="login-stat-badge">↑ 21%</div>
            </div>

        </div>
    </div>

    <!-- ═══════════ RIGHT — Login Form ═══════════ -->
    <div class="login-form-panel">
        <div class="login-form-inner">

            <div class="login-eyebrow">Admin Portal</div>
            <h2 class="login-title">Welcome back</h2>
            <p class="login-sub">Sign in to your admin account to continue.</p>

            @if (Model.Error is not null)
            {
                <div class="login-error" role="alert">
                    <svg class="login-error-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10" />
                        <line x1="12" y1="8" x2="12" y2="12" />
                        <line x1="12" y1="16" x2="12.01" y2="16" stroke-linecap="round" />
                    </svg>
                    @Model.Error
                </div>
            }

            <form asp-action="Login" asp-controller="Auth" method="post"
                  id="login-form" novalidate>
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="ReturnUrl" />

                <!-- Email -->
                <div class="form-group">
                    <label asp-for="Email" class="form-label">Email address</label>
                    <div class="form-input-wrap">
                        <svg class="form-icon" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M16 12a4 4 0 10-8 0 4 4 0 008 0zm0 0v1.5a2.5 2.5 0 005 0V12a9 9 0 10-9 9m4.5-1.206a8.959 8.959 0 01-4.5 1.207" />
                        </svg>
                        <input asp-for="Email"
                               type="email"
                               class="form-input form-input--icon @(ViewData.ModelState["Email"]?.Errors.Count > 0 ? "is-invalid" : "")"
                               placeholder="admin@example.com"
                               autocomplete="email"
                               autofocus>
                    </div>
                    <span asp-validation-for="Email" class="field-error"></span>
                </div>

                <!-- Password -->
                <div class="form-group">
                    <label asp-for="Password" class="form-label">Password</label>
                    <div class="form-input-wrap">
                        <svg class="form-icon" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                            <path stroke-linecap="round" stroke-linejoin="round" d="M7 11V7a5 5 0 0110 0v4" />
                        </svg>
                        <input asp-for="Password"
                               type="password"
                               id="password-input"
                               class="form-input form-input--icon @(ViewData.ModelState["Password"]?.Errors.Count > 0 ? "is-invalid" : "")"
                               placeholder="••••••••"
                               autocomplete="current-password">
                        <button type="button"
                                class="form-trailing"
                                id="pw-toggle"
                                aria-label="Toggle password visibility">
                            <svg id="pw-ico-show" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                            </svg>
                            <svg id="pw-ico-hide" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" hidden>
                                <path stroke-linecap="round" stroke-linejoin="round" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" />
                            </svg>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="field-error"></span>
                </div>

                <!-- Submit -->
                <button type="submit" class="btn btn-submit" id="submit-btn">
                    Sign in to Dashboard
                    <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                    </svg>
                </button>

            </form>

            <div class="form-note">
                <svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                </svg>
                Secured with 256-bit encryption · Admin access only
            </div>

        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/js/admin.js" asp-append-version="true"></script>

</body>
</html>
